# Development overrides – use Vite proxy so there are no mixed-content errors
# when running `npm run dev` in a browser on the laptop.
# These empty values make wsClient auto-use wss://same-host/ws (proxied)
# and keyServerApi use relative /keys paths (proxied).
# The .env absolute URLs are only used by `npm run build` (production/APK).
VITE_KEY_SERVER_URL=
VITE_RELAY_URL=
