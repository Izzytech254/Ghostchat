KEY_SERVER_PORT=8000
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# How long to keep a key bundle in Redis before purging (seconds)
KEY_TTL_SECONDS=2592000   # 30 days

# Max one-time pre-keys a user can upload at once
MAX_ONE_TIME_KEYS=100

# Log level: debug | info | warning | error
LOG_LEVEL=info
